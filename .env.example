# Smart Crop Advisory System
# Environment Variables Configuration

# ---------------------------------------------------------
# API Keys
# ---------------------------------------------------------

# Google Gemini API Key (Required for AI Chatbot and RAG features)
# Get one for free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ---------------------------------------------------------
# Backend Configuration (FastAPI)
# ---------------------------------------------------------
BACKEND_HOST="127.0.0.1"
BACKEND_PORT="8000"

# ---------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------
# Default is local SQLite: sqlite:///database/scas.db
# Uncomment to use PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/scas_db"
DATABASE_ECHO="false"

# ---------------------------------------------------------
# Voice/Speech Configuration
# ---------------------------------------------------------
WHISPER_MODEL_SIZE="small"
WHISPER_DEVICE="cpu"
WHISPER_COMPUTE_TYPE="int8"
